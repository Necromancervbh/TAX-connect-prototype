<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/space_2x"
    android:layout_marginBottom="@dimen/space_2x"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="@color/stroke"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/surface"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile Image Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">
            
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivProfileImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person"
                android:background="@color/surface_variant"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <!-- Verified Badge -->
            <ImageView
                android:id="@+id/ivVerifiedBadge"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/space_2x"
                android:src="@drawable/ic_verified_badge"
                android:visibility="gone"
                app:tint="@color/emerald_600"
                android:elevation="4dp"/>
        </FrameLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/space_3x"
            android:orientation="vertical">

            <!-- Name and Rating Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvCAName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CA Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★ 4.5"
                    android:textSize="12sp"
                    android:textColor="@color/amber_600"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tag_light"
                    android:paddingHorizontal="@dimen/space_1x"
                    android:paddingVertical="0dp"/>
            </LinearLayout>

            <!-- Specialization -->
            <TextView
                android:id="@+id/tvSpecialization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1x"
                android:text="GST • Income Tax"
                android:textSize="13sp"
                android:textColor="@color/text_muted" 
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Status -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1x"
                android:text="● Online"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="@dimen/space_2x"
                android:paddingVertical="0dp"
                android:background="@drawable/bg_rounded_chip"
                android:layout_marginEnd="@dimen/space_1x"/>

            <!-- Location and Experience -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2x"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_home" 
                    app:tint="@color/text_muted"
                    android:layout_marginEnd="0dp"/>
                
                <TextView
                    android:id="@+id/tvCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mumbai"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginEnd="@dimen/space_3x"/>

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/text_muted"
                    android:layout_marginEnd="0dp"/>

                <TextView
                    android:id="@+id/tvExperience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 Yrs"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Pricing -->
            <TextView
                android:id="@+id/tvMinCharges"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2x"
                android:text="Starts at ₹ 500"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_main" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_3x"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnect"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="48dp"
                    android:text="Connect"
                    android:paddingHorizontal="@dimen/space_3x"
                    android:paddingVertical="@dimen/space_2x"
                    app:icon="@drawable/ic_chat_bubble"
                    app:iconSize="14dp"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/space_1x"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary"
                    app:iconTint="@color/primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:layout_marginStart="@dimen/space_2x"
                    android:text="Save"
                    android:textColor="@color/primary"
                    android:paddingHorizontal="@dimen/space_2x"
                    android:paddingVertical="@dimen/space_2x"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>