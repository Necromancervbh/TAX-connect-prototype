<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_4x"
    android:layout_marginHorizontal="0dp"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="@color/surface_variant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/surface"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile Image Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">
            
            <ImageView
                android:id="@+id/ivProfileImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/surface_variant" />
            
            <!-- Gradient Overlay for better text visibility -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_overlay" />

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/space_3x"
                android:text="● Online"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/emerald_600"
                android:background="@drawable/bg_rounded_chip"
                android:paddingHorizontal="@dimen/space_2x"
                android:paddingVertical="@dimen/space_1x"/>
        </FrameLayout>

        <!-- Content Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/card_padding"
            android:orientation="vertical">

            <!-- Name and Rating Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvCAName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CA Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main"
                    android:fontFamily="sans-serif-medium"/>

                <ImageView
                    android:id="@+id/ivVerifiedBadge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="@dimen/space_1x"
                    android:src="@drawable/ic_verified_badge"
                    android:visibility="gone"
                    app:tint="@color/primary"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★ 4.5"
                    android:textSize="14sp"
                    android:textColor="@color/amber_600"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tag_light"
                    android:paddingHorizontal="@dimen/space_1x"
                    android:paddingVertical="0dp"/>
            </LinearLayout>

            <!-- Specialization -->
            <TextView
                android:id="@+id/tvSpecialization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_1x"
                android:text="GST • Income Tax • Auditing"
                android:textSize="14sp"
                android:textColor="@color/text_muted" 
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Location and Experience Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2x"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_home" 
                    app:tint="@color/text_muted"
                    android:layout_marginEnd="@dimen/space_1x"/>
                
                <TextView
                    android:id="@+id/tvCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mumbai"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginEnd="@dimen/space_4x"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/text_muted"
                    android:layout_marginEnd="@dimen/space_1x"/>

                <TextView
                    android:id="@+id/tvExperience"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 Yrs Exp."
                    android:textSize="13sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="@dimen/space_4x"
                android:layout_marginBottom="@dimen/space_3x"/>

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Pricing Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consultation"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"/>
                        
                    <TextView
                        android:id="@+id/tvMinCharges"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ 500"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main" />
                </LinearLayout>

                <!-- Action Buttons -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnect"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connect"
                    android:paddingHorizontal="@dimen/button_padding_horizontal"
                    android:paddingVertical="@dimen/button_padding_vertical"
                    app:icon="@drawable/ic_chat_bubble"
                    app:iconSize="16dp"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/space_2x"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary"
                    app:iconTint="@color/primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save"
                    android:textColor="@color/primary"
                    android:layout_marginStart="@dimen/space_2x"
                    android:paddingHorizontal="@dimen/space_3x"
                    android:paddingVertical="@dimen/space_2x"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>