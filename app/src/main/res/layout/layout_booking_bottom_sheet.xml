<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="16dp">

    <ImageView
        android:id="@+id/btnDragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_rounded_chip"
        android:backgroundTint="@color/slate_300"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerCA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnDragHandle">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCAAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_person_material3"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvCAName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="CA Name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintStart_toEndOf="@id/ivCAAvatar"
            app:layout_constraintTop_toTopOf="@id/ivCAAvatar"
            app:layout_constraintEnd_toStartOf="@id/tvPriceSummary"
            android:layout_marginStart="12dp"/>

        <TextView
            android:id="@+id/tvPriceSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Starts at â‚¹999"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.8"
            app:layout_constraintTop_toTopOf="@id/ivCAAvatar"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Select date &amp; time"
        android:textColor="?attr/colorOnSurface"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerCA" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <TextView
        android:id="@+id/tvAvailableSlots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Available Slots"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rvDates" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTimeSlots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="3"
        app:layout_constraintTop_toBottomOf="@id/tvAvailableSlots" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilBookingMessage"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Short message (optional)"
        app:layout_constraintTop_toBottomOf="@id/rvTimeSlots"
        app:layout_constraintBottom_toTopOf="@id/stickyConfirmBar">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBookingMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3"
            android:textColor="?attr/colorOnSurface" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/stickyConfirmBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/stroke"
        app:strokeWidth="1dp"
        app:cardBackgroundColor="@color/surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:baselineAligned="false">

            <TextView
                android:id="@+id/tvSelectionSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pick a date and time to send a booking request."
                android:textColor="@color/text_muted"
                style="@style/TextAppearance.Material3.BodySmall"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <TextView
                    android:id="@+id/tvTotalPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Estimated fee: â€”"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <Button
                    android:id="@+id/btnConfirmBooking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Request booking"
                    android:textColor="?attr/colorOnPrimary"
                    android:backgroundTint="@color/primary"
                    android:enabled="false"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

