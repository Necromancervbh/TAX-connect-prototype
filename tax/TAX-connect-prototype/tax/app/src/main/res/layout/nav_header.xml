<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="220dp"
    android:background="@drawable/bg_nav_header"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/nav_header_avatar_card"
        android:layout_width="216dp"
        android:layout_height="216dp"
        app:cardCornerRadius="108dp"
        app:cardElevation="0dp"
        app:strokeColor="?attr/colorOnPrimary"
        app:strokeWidth="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_header_name"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/nav_header_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person"
            android:background="?attr/colorSurfaceVariant" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/nav_header_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Guest User"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_header_email"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/nav_header_email"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Sign in to sync data"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnPrimary"
        android:alpha="0.8"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
