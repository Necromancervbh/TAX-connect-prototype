rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if the request is from an admin
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'vaibhavshukl23@gmail.com' || request.auth.token.admin == true);
    }

    // Helper: check if the request is from a specific user
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: check if the user is a participant in a conversation
    function isParticipant(conversationId) {
      return isAuthenticated() && 
             request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    // Helper: check if the user is part of a booking
    function isBookingParty() {
      let booking = resource.data;
      return isAuthenticated() && (request.auth.uid == booking.userId || request.auth.uid == booking.caId);
    }

    // Global rule for Admins: Admins can read everything
    match /{document=**} {
      allow read: if isAdmin();
    }

    // --- Collections ---

    // Users: Read any, write only self
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isUser(userId);
      allow update: if isUser(userId);
      allow delete: if false;

      // User Subcollections
      match /notifications/{id} {
        allow read, write: if isUser(userId);
      }
      match /documents/{id} {
        allow read, write: if isUser(userId);
      }
      match /favorites/{id} {
        allow read, write: if isUser(userId);
      }
      match /clients/{id} {
        allow read, write: if isUser(userId); // where userId is the CA
      }
      match /ratings/{id} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated(); // More complex logic based on conversation state could be added
        allow update: if false;
        allow delete: if false;
      }
    }

    // Conversations: Participant-only
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthenticated(); // Allow creating new conversations
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(conversationId);
        allow create: if isParticipant(conversationId);
        allow update: if isParticipant(conversationId);
        allow delete: if false;
      }
    }

    // Bookings: Party-only
    match /bookings/{bookingId} {
      allow read: if isBookingParty();
      allow create: if isAuthenticated();
      allow update: if isBookingParty();
      allow delete: if false;
    }

    // Transactions: Party-only, no updates
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.caId);
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Posts & Comments: Read all, write/delete author
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.authorId;
      }
    }

    // Services: Read all, write only CA
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.caId;
    }

    // Feedback: Write-only for users
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // Analytics: Write-only
    match /analytics/{id} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }

    // Archive: Admin only (deny all for now)
    match /archived_users/{userId} {
      allow read, write: if false;
    }

    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
