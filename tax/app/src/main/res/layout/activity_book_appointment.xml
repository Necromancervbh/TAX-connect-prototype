<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Book Appointment"
            app:titleCentered="true"
            app:navigationIcon="@drawable/ic_arrow_back_material3" 
            app:navigationIconTint="?attr/colorOnSurface"/>
            
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Stepper -->
        <include
            android:id="@+id/layoutStepper"
            layout="@layout/view_step_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Progress Bar for Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutStepper" />

        <!-- Content Area -->
        <ViewFlipper
            android:id="@+id/viewFlipper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Step 1: Select Service -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/screen_margin_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select a Service"
                        style="@style/TextAppearance.Material3.TitleLarge"
                        android:layout_marginBottom="@dimen/space_2x" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvServices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_service" />
                        
                    <TextView
                        android:id="@+id/tvNoServices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No services available for this expert."
                        android:gravity="center"
                        android:padding="32dp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Step 2: Schedule (Date & Time) -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/screen_margin_horizontal">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Date"
                        style="@style/TextAppearance.Material3.TitleMedium"
                        android:layout_marginBottom="@dimen/space_2x" />

                    <CalendarView
                        android:id="@+id/calendarView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_4x"
                        android:background="@drawable/bg_rounded_surface"
                        android:elevation="2dp"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Time Slot"
                        style="@style/TextAppearance.Material3.TitleMedium"
                        android:layout_marginBottom="@dimen/space_2x" />
                        
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTimeSlots"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_4x"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="3"
                        tools:listitem="@layout/item_time_slot_chip"/>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Step 3: Review & Confirm -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/screen_margin_horizontal">

                    <!-- Summary Card -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.Material3.CardView.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_4x">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/space_4x">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Booking Summary"
                                style="@style/TextAppearance.Material3.TitleMedium"
                                android:layout_marginBottom="@dimen/space_3x"/>

                            <!-- Expert Details -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="@dimen/space_3x">
                                
                                <ImageView
                                    android:id="@+id/ivExpertProfile"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_person_material3"
                                    android:background="@drawable/bg_circle_outline"
                                    android:scaleType="centerCrop"/>
                                    
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:layout_marginStart="@dimen/space_3x"
                                    android:gravity="center_vertical">
                                    
                                    <TextView
                                        android:id="@+id/tvExpertName"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="Dr. Tax Expert"
                                        style="@style/TextAppearance.Material3.TitleSmall"/>
                                        
                                    <TextView
                                        android:id="@+id/tvExpertTitle"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        tools:text="Chartered Accountant"
                                        style="@style/TextAppearance.Material3.BodySmall"/>
                                </LinearLayout>
                            </LinearLayout>
                            
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="?attr/colorOutlineVariant"
                                android:layout_marginBottom="@dimen/space_3x"/>
                                
                            <!-- Service Details -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Service"
                                style="@style/AppText.LabelMedium"/>
                            <TextView
                                android:id="@+id/tvSelectedService"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="Income Tax Filing"
                                style="@style/TextAppearance.Material3.BodyLarge"
                                android:layout_marginBottom="@dimen/space_2x"/>
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date &amp; Time"
                                style="@style/AppText.LabelMedium"/>
                            <TextView
                                android:id="@+id/tvSelectedDateTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="Mon, 15 Jan Ã¢â‚¬Â¢ 10:00 AM"
                                style="@style/TextAppearance.Material3.BodyLarge"
                                android:layout_marginBottom="@dimen/space_2x"/>
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Consultation Fee"
                                style="@style/AppText.LabelMedium"/>
                            <TextView
                                android:id="@+id/tvFee"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="Ã¢â€šÂ¹ 1500"
                                style="@style/TextAppearance.Material3.HeadlineSmall"
                                android:textColor="?attr/colorPrimary"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Add Note -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Add a note (Optional)">
                        
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="3"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </ViewFlipper>

        <!-- Bottom Navigation Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/screen_margin_horizontal"
            android:background="@color/surface"
            android:elevation="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Back"
                android:layout_marginEnd="@dimen/space_2x"
                android:visibility="invisible"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Next"
                android:layout_marginStart="@dimen/space_2x"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

