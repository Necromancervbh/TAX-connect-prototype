    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/item_chat_shimmer" />
        <include layout="@layout/item_chat_shimmer" />
        <include layout="@layout/item_chat_shimmer" />
        <include layout="@layout/item_chat_shimmer" />
        <include layout="@layout/item_chat_shimmer" />
        <include layout="@layout/item_chat_shimmer" />
        <include layout="@layout/item_chat_shimmer" />
        <include layout="@layout/item_chat_shimmer" />

    </LinearLayout>

</com.facebook.shimmer.ShimmerFrameLayout>
