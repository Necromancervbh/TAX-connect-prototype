<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/space_2x"
    android:paddingVertical="@dimen/space_2x">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/corner_radius_medium"
        app:cardElevation="2dp"
        android:visibility="gone"
        android:layout_marginBottom="@dimen/space_1x"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/ivChatPreview"
            android:layout_width="240dp"
            android:layout_height="180dp"
            android:contentDescription="Image attachment"
            android:scaleType="centerCrop" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineEnd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.75" />

    <LinearLayout
        android:id="@+id/layoutMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_received_modern"
        android:paddingHorizontal="@dimen/space_4x"
        android:paddingVertical="@dimen/space_3x"
        android:orientation="vertical"
        android:minWidth="96dp"
        android:maxWidth="280dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/guidelineEnd"
        app:layout_constraintTop_toBottomOf="@id/cardPreview"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constrainedWidth="true">

        <LinearLayout
            android:id="@+id/layoutDocument"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="@dimen/space_2x">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_document"
                android:contentDescription="Document Icon"
                app:tint="@color/primary"/>

            <TextView
                android:id="@+id/tvDocName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Document.pdf"
                android:textColor="@color/text_main"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvChatMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/text_main"
            android:lineSpacingExtra="4dp"
            android:fontFamily="sans-serif"/>

        <TextView
            android:id="@+id/tvChatTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="12:00 PM"
            style="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/text_muted"
            android:layout_marginTop="@dimen/space_2x"
            android:alpha="0.75"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

