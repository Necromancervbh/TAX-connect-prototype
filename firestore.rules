rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || resource.data.role == "CA");
      
      // Owner can write everything
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingCount']) &&
          existsAfter(/databases/$(database)/documents/users/$(userId)/ratings/$(request.auth.uid))
        )
      );

      // Ratings Subcollection
      // Path: users/{caId}/ratings/{raterId}
      match /ratings/{raterId} {
        allow read: if request.auth != null;
        
        // Only the rater can create/update their own rating.
        // CAs cannot delete/edit ratings because raterId != caId.
        allow write: if request.auth != null &&
          request.auth.uid == raterId &&
          request.resource.data.userId == raterId &&
          request.resource.data.caId == userId;
        
        // Note: To strictly enforce "only accepted clients", we would need a get() call 
        // to the conversations collection, which can be expensive. 
        // The client-side app enforces this via DataRepository.checkRatingEligibility.
      }

      // Clients Subcollection (for tracking unique clients)
      // Path: users/{caId}/clients/{clientId}
      match /clients/{clientId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Services Collection
    match /services/{serviceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.caId == request.auth.uid;
    }

    // Conversations Collection
    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;
    }

    // Bookings Collection
    match /bookings/{bookingId} {
       allow read, write: if request.auth != null && 
          (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.caId);
       allow create: if request.auth != null && 
          (request.auth.uid == request.resource.data.userId || request.auth.uid == request.resource.data.caId);
    }
  }
}
