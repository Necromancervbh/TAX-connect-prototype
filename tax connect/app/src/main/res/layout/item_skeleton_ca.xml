<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_3x"
    android:layout_marginHorizontal="@dimen/space_1x"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Image Placeholder -->
        <View
            android:id="@+id/viewImage"
            android:layout_width="0dp"
            android:layout_height="200dp"
            android:background="@color/surface_variant"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/card_padding"
            app:layout_constraintTop_toBottomOf="@id/viewImage">

            <!-- Name Placeholder -->
            <View
                android:id="@+id/viewName"
                android:layout_width="150dp"
                android:layout_height="24dp"
                android:background="@color/surface_variant"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Specialization Placeholder -->
            <View
                android:id="@+id/viewSpec"
                android:layout_width="200dp"
                android:layout_height="16dp"
                android:layout_marginTop="8dp"
                android:background="@color/surface_variant"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewName" />

            <!-- Details Placeholder -->
            <View
                android:id="@+id/viewDetails"
                android:layout_width="100dp"
                android:layout_height="16dp"
                android:layout_marginTop="16dp"
                android:background="@color/surface_variant"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewSpec" />

            <!-- Buttons Placeholder -->
            <View
                android:id="@+id/viewButtons"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:background="@color/surface_variant"
                app:layout_constraintTop_toBottomOf="@id/viewDetails" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>