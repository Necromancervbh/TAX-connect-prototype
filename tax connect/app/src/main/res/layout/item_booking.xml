<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_2x"
    android:layout_marginVertical="@dimen/space_1x"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="?attr/colorSurface"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_3x">

        <!-- Header Row: Avatar, Name, Status -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/bg_circle_gray"
            android:padding="8dp"
            app:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="@null"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_2x"
            android:layout_marginEnd="@dimen/space_2x"
            android:text="Client Name"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/ivAvatar"
            app:layout_constraintTop_toTopOf="@id/ivAvatar"
            app:layout_constraintEnd_toStartOf="@id/chipStatus"
            app:layout_constraintBottom_toTopOf="@id/tvRoleLabel"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvRoleLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tax Consultation"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvName"
            app:layout_constraintEnd_toStartOf="@id/chipStatus"
            app:layout_constraintBottom_toBottomOf="@id/ivAvatar" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="@color/amber_700"
            app:chipBackgroundColor="@color/amber_50"
            app:chipStrokeWidth="0dp"
            app:chipMinTouchTargetSize="32dp"
            android:clickable="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/ivAvatar" />

        <!-- Service Name -->
        <TextView
            android:id="@+id/tvServiceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tax Consultation"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="?attr/colorPrimary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/tvName"
            app:layout_constraintTop_toBottomOf="@id/tvRoleLabel"
            app:layout_constraintEnd_toStartOf="@id/chipStatus" />

        <!-- Divider -->
        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2x"
            app:layout_constraintTop_toBottomOf="@id/tvServiceName" />

        <!-- Date & Time Section -->
        <LinearLayout
            android:id="@+id/layoutDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2x"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_calendar"
                app:tint="?attr/colorPrimary"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_2x"
                android:text="Mon, 12 Oct • 10:00 AM"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Message Preview -->
        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2x"
            android:background="@drawable/bg_rounded_surface_variant"
            android:padding="@dimen/space_2x"
            android:text="Looking for assistance with GST filing for my new business..."
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/layoutDateTime" />

        <!-- Rejection Reason (shown to client on rejected bookings) -->
        <LinearLayout
            android:id="@+id/llRejectionReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1x"
            android:orientation="horizontal"
            android:background="?attr/colorErrorContainer"
            android:padding="@dimen/space_2x"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvMessage">

            <TextView
                android:id="@+id/tvRejectionReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reason: Not available at this time"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorError" />

        </LinearLayout>

        <!-- Action Buttons -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2x"
            android:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/llRejectionReason">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/space_1x"
                android:text="Decline"
                android:textColor="?attr/colorError"
                app:strokeColor="?attr/colorError"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnAccept"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_1x"
                android:text="Accept"
                app:layout_constraintStart_toEndOf="@id/btnReject"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Add to Calendar Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddToCalendar"
            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2x"
            android:text="@string/add_to_calendar"
            android:visibility="gone"
            tools:visibility="visible"
            app:icon="@drawable/ic_calendar"
            app:iconGravity="textStart"
            app:strokeColor="?attr/colorSecondary"
            android:textColor="?attr/colorSecondary"
            app:layout_constraintTop_toBottomOf="@id/layoutActions" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMilestones"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_1x"
            android:text="View Details"
            android:visibility="gone"
            tools:visibility="visible"
            app:icon="@drawable/ic_arrow_forward"
            app:iconGravity="textEnd"
            app:layout_constraintTop_toBottomOf="@id/btnAddToCalendar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkComplete"
            style="@style/Widget.Material3.Button.TextButton.Icon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="\u2705 Mark as Complete"
            android:textColor="@color/emerald_700"
            android:visibility="gone"
            app:icon="@drawable/ic_check_circle"
            app:iconTint="@color/emerald_700"
            app:layout_constraintTop_toBottomOf="@id/btnMilestones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 3-Step Timeline (shown for COMPLETED bookings) -->
        <LinearLayout
            android:id="@+id/layoutTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_3x"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btnMarkComplete">

            <!-- Step 1: Booked -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_light_primary"
                    android:backgroundTint="?attr/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Booked"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Connector -->
            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.5"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@android:color/darker_gray" />

            <!-- Step 2: Accepted -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_light_primary"
                    android:backgroundTint="?attr/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accepted"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Connector -->
            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="0.5"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@android:color/darker_gray" />

            <!-- Step 3: Completed -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_light_primary"
                    android:backgroundTint="?attr/colorTertiary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Done"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="?attr/colorTertiary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>