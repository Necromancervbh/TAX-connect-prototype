<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_primary"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarWallet"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="My Wallet"
            app:titleCentered="true"
            app:titleTextColor="?attr/colorOnPrimary"
            app:navigationIcon="@drawable/ic_arrow_back_material3"
            app:navigationIconTint="?attr/colorOnPrimary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_margin_horizontal"
            android:paddingTop="@dimen/space_5x"
            android:paddingBottom="@dimen/space_6x">

            <!-- Premium Gradient Balance Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_6x"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient_primary"
                    android:padding="@dimen/space_6x">

                    <TextView
                        android:id="@+id/labelBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Balance"
                        style="@style/TextAppearance.Material3.BodySmall"
                        android:textColor="?attr/colorOnPrimary"
                        android:alpha="0.8"
                        android:letterSpacing="0.05"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvWalletBalance"
                        android:layout_below="@id/labelBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_2x"
                        android:text="&#x20B9; 0.00"
                        android:textColor="?attr/colorOnPrimary"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_wallet_material3"
                        android:contentDescription="Wallet icon"
                        android:alpha="0.2"
                        app:tint="?attr/colorOnPrimary" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="@dimen/space_8x">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeposit"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/button_min_height"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/space_2x"
                    android:text="Add Money"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnPrimary"
                    app:icon="@drawable/ic_add_circle"
                    app:iconTint="?attr/colorOnPrimary"
                    app:iconGravity="textStart"
                    app:cornerRadius="@dimen/button_corner_radius"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWithdraw"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/button_min_height"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_2x"
                    android:text="Withdraw"
                    android:textSize="16sp"
                    android:textColor="@color/primary"
                    app:strokeColor="@color/primary"
                    app:icon="@drawable/ic_arrow_upward"
                    app:iconTint="@color/primary"
                    app:iconGravity="textStart"
                    app:cornerRadius="@dimen/button_corner_radius"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_3x"
                android:text="Recent Transactions"
                style="@style/TextAppearance.Material3.TitleLarge"
                android:textSize="18sp"/>

            <include
                android:id="@+id/shimmerViewContainer"
                layout="@layout/shimmer_transactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTransactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layoutAnimation="@anim/layout_animation_fall_down"
                tools:listitem="@layout/item_transaction"/>

            <include
                android:id="@+id/layoutEmptyState"
                layout="@layout/component_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <include
                android:id="@+id/layoutErrorState"
                layout="@layout/component_error_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

