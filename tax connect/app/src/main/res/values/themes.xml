<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Enhanced Material 3 Theme - 2026 Standards -->
    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Material 3 Color System -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>
        
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>
        
        <item name="colorTertiary">@color/md_theme_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_onTertiaryContainer</item>
        
        <item name="colorError">@color/md_theme_error</item>
        <item name="colorOnError">@color/md_theme_onError</item>
        <item name="colorErrorContainer">@color/md_theme_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_onErrorContainer</item>
        
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_onSurfaceVariant</item>
        
        <item name="colorOutline">@color/md_theme_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_outlineVariant</item>
        
        <item name="colorOnSurfaceInverse">@color/md_theme_inverseOnSurface</item>
        <item name="colorSurfaceInverse">@color/md_theme_inverseSurface</item>
        <item name="colorPrimaryInverse">@color/md_theme_inversePrimary</item>

        <!-- Enhanced Status Bar -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Window Animations -->
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>

        <!-- Enhanced Typography with Tight, Modern Letter Spacing -->
        <item name="textAppearanceDisplayLarge">@style/AppText.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/AppText.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/AppText.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/AppText.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/AppText.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/AppText.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/AppText.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/AppText.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/AppText.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/AppText.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/AppText.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/AppText.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/AppText.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/AppText.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/AppText.LabelSmall</item>

        <!-- Enhanced Component Styles -->
        <item name="materialButtonStyle">@style/AppButton.Material3</item>
        <item name="materialCardViewStyle">@style/AppCard.Material3</item>
        <item name="textInputStyle">@style/AppTextInputLayout.Material3</item>
        <item name="chipStyle">@style/AppChip.Material3</item>
        <item name="floatingActionButtonStyle">@style/AppFab.Material3</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheet.Material3</item>
        <item name="navigationViewStyle">@style/AppNavigationView.Material3</item>
        <item name="toolbarStyle">@style/AppToolbar.Material3</item>
        <item name="appBarLayoutStyle">@style/AppAppBar.Material3</item>
        
        <!-- Shape System -->
        <item name="shapeAppearanceSmallComponent">@style/AppShapeAppearance.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/AppShapeAppearance.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/AppShapeAppearance.Large</item>
        
        <!-- Motion System -->
        <item name="motionDurationShort1">@integer/motion_duration_short1</item>
        <item name="motionDurationShort2">@integer/motion_duration_short2</item>
        <item name="motionDurationMedium1">@integer/motion_duration_medium1</item>
        <item name="motionDurationMedium2">@integer/motion_duration_medium2</item>
        <item name="motionDurationLong1">@integer/motion_duration_long1</item>
        <item name="motionDurationLong2">@integer/motion_duration_long2</item>
        <item name="motionEasingStandard">@android:interpolator/fast_out_slow_in</item>
        <item name="motionEasingAccelerated">@android:interpolator/fast_out_linear_in</item>
        <item name="motionEasingDecelerated">@android:interpolator/linear_out_slow_in</item>
    </style>
    
    <!-- Enhanced Typography Scale -->
    <!-- Display Styles -->
    <style name="AppText.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">57sp</item>
        <item name="android:lineHeight" tools:targetApi="p">64sp</item>
        <item name="android:letterSpacing">-0.25</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textSize">45sp</item>
        <item name="android:lineHeight" tools:targetApi="p">52sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">36sp</item>
        <item name="android:lineHeight" tools:targetApi="p">44sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Headline Styles -->
    <style name="AppText.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:lineHeight" tools:targetApi="p">40sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight" tools:targetApi="p">36sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight" tools:targetApi="p">32sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Title Styles -->
    <style name="AppText.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:lineHeight" tools:targetApi="p">28sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight" tools:targetApi="p">24sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight" tools:targetApi="p">20sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Body Styles -->
    <style name="AppText.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight" tools:targetApi="p">24sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight" tools:targetApi="p">20sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight" tools:targetApi="p">16sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Label Styles -->
    <style name="AppText.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:lineHeight" tools:targetApi="p">20sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight" tools:targetApi="p">16sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="AppText.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:lineHeight" tools:targetApi="p">16sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>
    
    <!-- Enhanced Button Styles -->
    <style name="AppButton.Material3" parent="Widget.Material3.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@animator/button_press_animator</item>
    </style>
    
    <style name="AppButton.Material3.Elevated" parent="Widget.Material3.Button.ElevatedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="elevation">1dp</item>
    </style>
    
    <style name="AppButton.Material3.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="AppButton.Material3.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <!-- Enhanced Card Styles -->
    <style name="AppCard.Material3" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardPreventCornerOverlap">true</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <style name="AppCard.Material3.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardPreventCornerOverlap">true</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <style name="AppCard.Material3.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardPreventCornerOverlap">true</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <style name="AppCard.Material3.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardPreventCornerOverlap">true</item>
        <item name="strokeWidth">0dp</item>
    </style>
    
    <!-- Enhanced Text Input Styles -->
    <style name="AppTextInputLayout.Material3" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">?attr/colorPrimary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>
    
    <!-- Enhanced Chip Styles -->
    <style name="AppChip.Material3" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="chipStartPadding">12dp</item>
        <item name="chipEndPadding">12dp</item>
        <item name="chipIconSize">18dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Enhanced FAB Styles -->
    <style name="AppFab.Material3" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="fabCustomSize">56dp</item>
        <item name="maxImageSize">24dp</item>
        <item name="elevation">3dp</item>
        <item name="backgroundTint">?attr/colorPrimaryContainer</item>
        <item name="tint">?attr/colorOnPrimaryContainer</item>
    </style>
    
    <!-- Enhanced Bottom Sheet Styles -->
    <style name="AppBottomSheet.Material3" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppBottomSheetStyle.Material3</item>
    </style>
    
    <style name="AppBottomSheetStyle.Material3" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/AppShapeAppearance.Large</item>
        <item name="backgroundTint">?attr/colorSurface</item>
    </style>
    
    <!-- Enhanced Navigation Styles -->
    <style name="AppNavigationView.Material3" parent="Widget.Material3.NavigationView">
        <item name="itemIconTint">@color/nav_item_tint</item>
        <item name="itemTextColor">@color/nav_item_tint</item>
        <item name="itemBackground">@drawable/nav_item_background</item>
        <item name="itemShapeAppearance">@style/AppShapeAppearance.Medium</item>
        <item name="itemShapeInsetStart">12dp</item>
        <item name="itemShapeInsetEnd">12dp</item>
        <item name="itemVerticalPadding">8dp</item>
        <item name="itemHorizontalPadding">20dp</item>
        <item name="itemIconSize">24dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:listDivider">@null</item>
        <item name="headerLayout">@layout/nav_header</item>
    </style>
    
    <!-- Enhanced Toolbar Styles -->
    <style name="AppToolbar.Material3" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="subtitleTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="navigationIconTint">?attr/colorOnSurface</item>
    </style>
    
    <!-- Enhanced App Bar Styles -->
    <style name="AppAppBar.Material3" parent="Widget.Material3.AppBarLayout">
        <item name="android:background">?attr/colorSurface</item>
        <item name="elevation">0dp</item>
    </style>
    
    <!-- Enhanced Shape Appearances -->
    <style name="AppShapeAppearance.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>
    
    <style name="AppShapeAppearance.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="AppShapeAppearance.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    

    
    <!-- Theme Variants -->
    <style name="Theme.Transparent" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="WindowAnimationTransition">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

</resources>