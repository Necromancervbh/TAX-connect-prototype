    <dimen name="elevation_5">12dp</dimen>         <!-- Modal bottom sheets -->
    
    <dimen name="card_elevation">@dimen/elevation_1</dimen>
    <dimen name="card_corner_radius">16dp</dimen>
    
    <!-- Material 3 Corner Radius Scale -->
    <dimen name="corner_radius_small">12dp</dimen>      <!-- Chips, small cards, buttons -->
    <dimen name="corner_radius_medium">16dp</dimen>     <!-- Standard cards, dialogs -->
    <dimen name="corner_radius_large">20dp</dimen>      <!-- Hero cards, feature elements -->
    <dimen name="corner_radius_pill">28dp</dimen>       <!-- Search bars, pill buttons -->
    <dimen name="corner_radius_full">999dp</dimen>      <!-- Circular elements -->
    
    <dimen name="button_padding_vertical">@dimen/space_3x</dimen>
    <dimen name="button_padding_horizontal">@dimen/space_6x</dimen>
