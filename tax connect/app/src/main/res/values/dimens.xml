    <dimen name="elevation_0">0dp</dimen>          <!-- Flush surfaces -->
    <dimen name="elevation_1">1dp</dimen>          <!-- Cards, chips -->
    <dimen name="elevation_2">3dp</dimen>          <!-- FABs, raised buttons -->
